{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"mini-shawn","text":"<p>mini-shawn \u306f\u3001\u6cb3\u4e0a\u306e\u7d4c\u9a13\u30fb\u77e5\u8b58\u30fb\u5224\u65ad\u57fa\u6e96\u3092\u8a00\u8a9e\u5316\u3057\u3001\u63a1\u7528\u30fb\u7d44\u7e54\u30fb\u4eba\u4e8b\u696d\u52d9\u306e\u4f01\u753b/\u63a8\u9032/\u904b\u55b6\u3092\u652f\u63f4\u3059\u308b\u305f\u3081\u306e\u5b9f\u9a13\u7528\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3067\u3059\u3002</p> <p>\u3053\u306e\u30ea\u30dd\u30b8\u30c8\u30ea\u3067\u306f\u3001\u4ee5\u4e0b\u3092\u6574\u7406\u30fb\u516c\u958b\u3057\u3066\u3044\u304d\u307e\u3059\u3002</p> <ul> <li>\u63a1\u7528\u30fb\u7d44\u7e54\u30fb\u4eba\u4e8b\u306b\u95a2\u3059\u308b\u77e5\u8b58</li> <li>\u5b9f\u52d9\u3067\u4f7f\u3048\u308b\u30c6\u30f3\u30d7\u30ec\u30fc\u30c8\u3084\u30d7\u30ec\u30a4\u30d6\u30c3\u30af</li> <li>AI\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u304c\u53c2\u7167\u3057\u3084\u3059\u3044\u5224\u65ad\u30eb\u30fc\u30eb</li> <li>Claude Code \u306a\u3069\u3067\u518d\u5229\u7528\u3067\u304d\u308b\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u5b9a\u7fa9</li> </ul>"},{"location":"#_1","title":"\u3053\u306e\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u3067\u76ee\u6307\u3059\u3053\u3068","text":"<ul> <li>\u5b9f\u52d9\u77e5\u898b\u3092\u518d\u5229\u7528\u53ef\u80fd\u306a\u5f62\u3067\u69cb\u9020\u5316\u3059\u308b</li> <li>AI\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u304c\u8aad\u307f\u3084\u3059\u3044\u5f62\u3067\u84c4\u7a4d\u3059\u308b</li> <li>\u4ed6\u306e\u4eba\u304c\u5c0e\u5165\u3057\u3066\u696d\u52d9\u652f\u63f4\u306b\u4f7f\u3048\u308b\u72b6\u614b\u306b\u3059\u308b</li> <li>\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u516c\u958b\u3068\u904b\u7528\u8cc7\u7523\u7ba1\u7406\u3092\u4e21\u7acb\u3059\u308b</li> </ul>"},{"location":"#_2","title":"\u4e3b\u306a\u30e6\u30fc\u30b9\u30b1\u30fc\u30b9","text":"<ul> <li>\u6c42\u4eba\u7968\u306e\u6539\u5584</li> <li>\u63a1\u7528\u6226\u7565\u306e\u6574\u7406</li> <li>\u30ab\u30b8\u30e5\u30a2\u30eb\u9762\u8ac7\u30fb\u9762\u63a5\u8a2d\u8a08</li> <li>Value\u8a2d\u8a08\u3068\u6d78\u900f\u65bd\u7b56\u6574\u7406</li> <li>\u63a1\u7528\u30aa\u30da\u30ec\u30fc\u30b7\u30e7\u30f3\u6539\u5584</li> <li>\u4eba\u4e8b\u95a2\u9023\u306e\u8ad6\u70b9\u6574\u7406\u3068\u305f\u305f\u304d\u53f0\u4f5c\u6210</li> </ul>"},{"location":"#_3","title":"\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u306e\u8003\u3048\u65b9","text":"<ul> <li><code>docs/</code> : \u4eba\u304c\u8aad\u3080\u305f\u3081\u306e\u516c\u958b\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8</li> <li><code>knowledge/</code> : \u5b9f\u52d9\u77e5\u898b\u306e\u672c\u4f53</li> <li><code>agents/</code> : \u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306e\u5f79\u5272\u5b9a\u7fa9</li> <li><code>prompts/</code> : \u30bf\u30b9\u30af\u5b9f\u884c\u7528\u306e\u6307\u793a</li> <li><code>evals/</code> : \u54c1\u8cea\u691c\u8a3c\u7528\u306e\u8cc7\u7523</li> </ul>"},{"location":"#_4","title":"\u6ce8\u610f","text":"<p>\u3053\u306e\u30ea\u30dd\u30b8\u30c8\u30ea\u306e\u5185\u5bb9\u306f\u5224\u65ad\u652f\u63f4\u3092\u76ee\u7684\u3068\u3057\u305f\u3082\u306e\u3067\u3059\u3002\u5b9f\u969b\u306e\u63a1\u7528\u30fb\u7d44\u7e54\u30fb\u52b4\u52d9\u30fb\u6cd5\u52d9\u5224\u65ad\u3067\u306f\u3001\u5fc5\u8981\u306b\u5fdc\u3058\u3066\u5c02\u9580\u5bb6\u78ba\u8a8d\u3092\u884c\u3063\u3066\u304f\u3060\u3055\u3044\u3002</p>"}]}